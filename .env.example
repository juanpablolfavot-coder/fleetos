# ══════════════════════════════════════════
#  FleetOS — Variables de entorno
#  NUNCA subir este archivo a GitHub
#  Copiar como .env y completar los valores
# ══════════════════════════════════════════

# Base de datos PostgreSQL (Render PostgreSQL o Supabase)
DATABASE_URL=postgresql://usuario:contraseña@host:5432/fleetos

# JWT Secret — generá uno aleatorio con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_STRING_ALEATORIO_MUY_LARGO_64_CHARS_MINIMO
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# Servidor
PORT=3000
NODE_ENV=production

# Seguridad
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME_MINUTES=15

# CORS — URL(s) del frontend (tu dominio de Render). Acepta varias separadas por coma.
# Si se completa, CORS se restringe a estos orígenes. Si se deja vacío, se mantiene
# el comportamiento permisivo previo (no recomendado en producción).
FRONTEND_URL=https://fleetos.onrender.com

# GPS Powerfleet (Rusegur) — credenciales del proveedor de monitoreo.
# OBLIGATORIAS para que funcione el sync GPS. Sin ellas, el GPS queda desactivado
# (el resto del sistema funciona normal). NUNCA hardcodearlas en el código.
GPS_USER=
GPS_PASSWORD=
# Dejar en false (o sin definir) para validar el certificado TLS del proveedor.
# Poner true SOLO si el proveedor usa un certificado que no valida y se corta el sync.
GPS_TLS_INSECURE=false

# IA del panel auditor (Anthropic). Opcional: si falta, el endpoint /api/auditor/ia
# responde 503 y el resto del panel funciona igual.
ANTHROPIC_API_KEY=

# Contraseña del usuario admin inicial que crea db/migrate.js.
# Si se deja vacía, el script genera una aleatoria y la imprime UNA vez en consola.
ADMIN_PASSWORD=

# Logs
LOG_LEVEL=warn

# ── Backup automático por email (scripts/backup-email.js / Cron Job de Render) ──
# Estas SOLO hacen falta en el servicio Cron Job de backup, no en la web.
# Destinatario del backup (a dónde te llega el .sql.gz).
BACKUP_EMAIL_TO=tu-email@gmail.com
# SMTP. Para Gmail: SMTP_USER es tu Gmail y SMTP_PASS es una "App Password" de 16
# caracteres (Cuenta de Google → Seguridad → Verificación en 2 pasos → Contraseñas
# de aplicaciones). NO es tu contraseña normal de Gmail.
SMTP_USER=tu-email@gmail.com
SMTP_PASS=xxxxxxxxxxxxxxxx
# Opcionales (valores por defecto pensados para Gmail):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
# Límite de adjunto en MB (Gmail corta en ~25). Si el dump supera esto, manda aviso sin adjunto.
BACKUP_MAX_MB=20

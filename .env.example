# ══════════════════════════════════════════
#  FleetOS — Variables de entorno
#  NUNCA subir este archivo a GitHub
#  Copiar como .env y completar los valores
# ══════════════════════════════════════════

# Base de datos PostgreSQL (Render PostgreSQL o Supabase)
DATABASE_URL=postgresql://usuario:contraseña@host:5432/fleetos

# JWT Secret — generá uno aleatorio con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_STRING_ALEATORIO_MUY_LARGO_64_CHARS_MINIMO
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# Servidor
PORT=3000
NODE_ENV=production

# Seguridad
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME_MINUTES=15

# CORS — URL del frontend (tu dominio de Render)
FRONTEND_URL=https://fleetos.onrender.com

# Logs
LOG_LEVEL=warn
